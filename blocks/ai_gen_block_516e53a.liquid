{% doc %}
  @prompt
    Create a hero banner section with a full-width background image and separate mobile background image upload option. The banner should have a semi-transparent black overlay. Center a text box containing a large white heading, a smaller description text below it, and two call-to-action buttons positioned side-by-side. Include customization settings for: desktop and mobile background images, overlay opacity, heading text and color, description text and color, button labels and links, font sizes, text formatting (bold/italic), spacing controls (top and bottom padding), and desktop/mobile visibility options.
    
    Custom CSS Settings to include:
    
    Font size controls for heading and description
    Font color pickers for all text elements
    Separate image uploads for desktop and mobile
    Top and bottom spacing/padding adjustments
    Text formatting options: bold toggle, italic toggle, and link field
    Desktop/Mobile visibility controls
    Overlay opacity control
    Design specifications:
    
    Full-width background image with mobile alternative
    Semi-transparent black overlay
    Centered content box
    Large white heading
    Smaller description text
    Two side-by-side CTA buttons
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-hero-banner-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
  }

  .ai-hero-banner-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-hero-banner-background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-banner-background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-banner-background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-hero-banner-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, {{ block.settings.overlay_opacity }});
    z-index: 2;
  }

  .ai-hero-banner-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    text-align: center;
    max-width: 800px;
    padding: 40px 20px;
  }

  .ai-hero-banner-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_font_size }}px;
    margin: 0 0 20px;
    {% if block.settings.heading_bold %}font-weight: 700;{% endif %}
    {% if block.settings.heading_italic %}font-style: italic;{% endif %}
  }

  .ai-hero-banner-description-{{ ai_gen_id }} {
    color: {{ block.settings.description_color }};
    font-size: {{ block.settings.description_font_size }}px;
    margin: 0 0 30px;
    line-height: 1.6;
    {% if block.settings.description_bold %}font-weight: 700;{% endif %}
    {% if block.settings.description_italic %}font-style: italic;{% endif %}
  }

  .ai-hero-banner-buttons-{{ ai_gen_id }} {
    display: flex;
    gap: 15px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .ai-hero-banner-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 15px 30px;
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-hero-banner-button-primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_primary_bg }};
    color: {{ block.settings.button_primary_text }};
  }

  .ai-hero-banner-button-primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_primary_hover_bg }};
    color: {{ block.settings.button_primary_hover_text }};
  }

  .ai-hero-banner-button-secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_secondary_bg }};
    color: {{ block.settings.button_secondary_text }};
  }

  .ai-hero-banner-button-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_secondary_hover_bg }};
    color: {{ block.settings.button_secondary_hover_text }};
  }

  .ai-hero-banner-mobile-bg-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-hero-banner-wrapper-{{ ai_gen_id }} {
      min-height: 300px;
      padding-top: {{ block.settings.padding_top_mobile }}px;
      padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-hero-banner-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_font_size | times: 0.7 }}px;
    }

    .ai-hero-banner-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_font_size | times: 0.85 }}px;
    }

    .ai-hero-banner-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
      padding: 12px 24px;
    }

    .ai-hero-banner-buttons-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: stretch;
    }

    .ai-hero-banner-desktop-bg-{{ ai_gen_id }} {
      {% if block.settings.mobile_image %}display: none;{% endif %}
    }

    .ai-hero-banner-mobile-bg-{{ ai_gen_id }} {
      {% if block.settings.mobile_image %}display: block;{% endif %}
    }

    {% if block.settings.hide_on_mobile %}
      .ai-hero-banner-{{ ai_gen_id }} {
        display: none;
      }
    {% endif %}
  }

  @media screen and (min-width: 750px) {
    {% if block.settings.hide_on_desktop %}
      .ai-hero-banner-{{ ai_gen_id }} {
        display: none;
      }
    {% endif %}
  }
{% endstyle %}

<hero-banner-{{ ai_gen_id }} class="ai-hero-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-banner-wrapper-{{ ai_gen_id }}">
    <div class="ai-hero-banner-background-{{ ai_gen_id }}">
      {% if block.settings.desktop_image %}
        <div class="ai-hero-banner-desktop-bg-{{ ai_gen_id }}">
          <img
            src="{{ block.settings.desktop_image | image_url: width: 2000 }}"
            alt="{{ block.settings.desktop_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.desktop_image.width }}"
            height="{{ block.settings.desktop_image.height }}"
          >
        </div>
      {% else %}
        <div class="ai-hero-banner-background-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}

      {% if block.settings.mobile_image %}
        <div class="ai-hero-banner-mobile-bg-{{ ai_gen_id }}">
          <img
            src="{{ block.settings.mobile_image | image_url: width: 1000 }}"
            alt="{{ block.settings.mobile_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.mobile_image.width }}"
            height="{{ block.settings.mobile_image.height }}"
          >
        </div>
      {% endif %}
    </div>

    <div class="ai-hero-banner-overlay-{{ ai_gen_id }}"></div>

    <div class="ai-hero-banner-content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h1 class="ai-hero-banner-heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h1>
      {% endif %}

      {% if block.settings.description != blank %}
        <div class="ai-hero-banner-description-{{ ai_gen_id }}">
          {{ block.settings.description }}
        </div>
      {% endif %}

      <div class="ai-hero-banner-buttons-{{ ai_gen_id }}">
        {% if block.settings.button_primary_label != blank %}
          <a
            href="{{ block.settings.button_primary_link }}"
            class="ai-hero-banner-button-{{ ai_gen_id }} ai-hero-banner-button-primary-{{ ai_gen_id }}"
          >
            {{ block.settings.button_primary_label }}
          </a>
        {% endif %}

        {% if block.settings.button_secondary_label != blank %}
          <a
            href="{{ block.settings.button_secondary_link }}"
            class="ai-hero-banner-button-{{ ai_gen_id }} ai-hero-banner-button-secondary-{{ ai_gen_id }}"
          >
            {{ block.settings.button_secondary_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</hero-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class HeroBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.adjustMinHeight();
        window.addEventListener('resize', () => this.adjustMinHeight());
      }

      adjustMinHeight() {
        const wrapper = this.querySelector('.ai-hero-banner-wrapper-{{ ai_gen_id }}');
        if (wrapper) {
          const img = wrapper.querySelector('img');
          if (img && img.complete) {
            const aspectRatio = img.naturalHeight / img.naturalWidth;
            const calculatedHeight = wrapper.offsetWidth * aspectRatio;
            if (calculatedHeight > 400) {
              wrapper.style.minHeight = calculatedHeight + 'px';
            }
          }
        }
      }
    }

    customElements.define('hero-banner-{{ ai_gen_id }}', HeroBanner{{ ai_gen_id }});
  })();
</script>

