{% doc %}
  @prompt
    Create a hero banner with a full-width background image. Center a text box with a large white heading, a smaller description, and two side-by-side CTA buttons. Ensure the overlay is semi-transparent black., can we have mobile image upload 
    and also overlay color setting for the background image
    , can we set the text to have options to bold italic or even add link
    can check also the overlay not working
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    min-height: {{ block.settings.min_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .ai-hero-banner-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-hero-banner-background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-banner-background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-hero-banner-background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-hero-banner-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-hero-banner-background-desktop-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: 100%;
  }

  .ai-hero-banner-background-mobile-{{ ai_gen_id }} {
    display: none;
    width: 100%;
    height: 100%;
  }

  .ai-hero-banner-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
    pointer-events: none;
  }

  .ai-hero-banner-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    max-width: {{ block.settings.content_max_width }}px;
    padding: 40px 20px;
    text-align: center;
    background-color: {{ block.settings.text_box_background }};
    border-radius: {{ block.settings.text_box_radius }}px;
  }

  .ai-hero-banner-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 20px;
    line-height: 1.2;
  }

  .ai-hero-banner-heading-{{ ai_gen_id }} p,
  .ai-hero-banner-heading-{{ ai_gen_id }} h1,
  .ai-hero-banner-heading-{{ ai_gen_id }} h2,
  .ai-hero-banner-heading-{{ ai_gen_id }} h3 {
    margin: 0;
    font-size: inherit;
    color: inherit;
    line-height: inherit;
  }

  .ai-hero-banner-heading-{{ ai_gen_id }} a {
    color: inherit;
    text-decoration: underline;
  }

  .ai-hero-banner-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0 0 30px;
    line-height: 1.5;
  }

  .ai-hero-banner-description-{{ ai_gen_id }} p {
    margin: 0 0 10px;
  }

  .ai-hero-banner-description-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-hero-banner-description-{{ ai_gen_id }} a {
    color: inherit;
    text-decoration: underline;
  }

  .ai-hero-banner-buttons-{{ ai_gen_id }} {
    display: flex;
    gap: 15px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .ai-hero-banner-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 15px 30px;
    font-size: {{ block.settings.button_text_size }}px;
    text-decoration: none;
    border-radius: {{ block.settings.button_radius }}px;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-hero-banner-button-primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_primary_bg }};
    color: {{ block.settings.button_primary_color }};
  }

  .ai-hero-banner-button-primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_primary_hover_bg }};
    color: {{ block.settings.button_primary_hover_color }};
  }

  .ai-hero-banner-button-secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_secondary_bg }};
    color: {{ block.settings.button_secondary_color }};
  }

  .ai-hero-banner-button-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_secondary_hover_bg }};
    color: {{ block.settings.button_secondary_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-hero-banner-{{ ai_gen_id }} {
      min-height: {{ block.settings.min_height_mobile }}px;
    }

    .ai-hero-banner-background-desktop-{{ ai_gen_id }} {
      display: {% if block.settings.background_image_mobile %}none{% else %}block{% endif %};
    }

    .ai-hero-banner-background-mobile-{{ ai_gen_id }} {
      display: {% if block.settings.background_image_mobile %}block{% else %}none{% endif %};
    }

    .ai-hero-banner-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
    }

    .ai-hero-banner-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.8 }}px;
    }

    .ai-hero-banner-content-{{ ai_gen_id }} {
      padding: 30px 15px;
    }

    .ai-hero-banner-buttons-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 10px;
    }

    .ai-hero-banner-button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-hero-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-banner-background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <div class="ai-hero-banner-background-desktop-{{ ai_gen_id }}">
        <img
          src="{{ block.settings.background_image | image_url: width: 2000 }}"
          alt="{{ block.settings.background_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.background_image.width }}"
          height="{{ block.settings.background_image.height }}"
        >
      </div>
    {% endif %}

    {% if block.settings.background_image_mobile %}
      <div class="ai-hero-banner-background-mobile-{{ ai_gen_id }}">
        <img
          src="{{ block.settings.background_image_mobile | image_url: width: 1000 }}"
          alt="{{ block.settings.background_image_mobile.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.background_image_mobile.width }}"
          height="{{ block.settings.background_image_mobile.height }}"
        >
      </div>
    {% endif %}

    {% if block.settings.background_image == blank and block.settings.background_image_mobile == blank %}
      <div class="ai-hero-banner-background-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-hero-banner-empty-state-{{ ai_gen_id }}">
          Next, add a background image
        </div>
      </div>
    {% endif %}
  </div>

  <div 
    class="ai-hero-banner-overlay-{{ ai_gen_id }}"
    style="background-color: {{ block.settings.overlay_color }}; opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};"
  ></div>

  <div class="ai-hero-banner-content-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <div class="ai-hero-banner-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</div>
    {% endif %}

    {% if block.settings.description != blank %}
      <div class="ai-hero-banner-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
    {% endif %}

    {% if block.settings.button_primary_label != blank or block.settings.button_secondary_label != blank %}
      <div class="ai-hero-banner-buttons-{{ ai_gen_id }}">
        {% if block.settings.button_primary_label != blank %}
          <a
            href="{{ block.settings.button_primary_link }}"
            class="ai-hero-banner-button-{{ ai_gen_id }} ai-hero-banner-button-primary-{{ ai_gen_id }}"
          >
            {{ block.settings.button_primary_label }}
          </a>
        {% endif %}

        {% if block.settings.button_secondary_label != blank %}
          <a
            href="{{ block.settings.button_secondary_link }}"
            class="ai-hero-banner-button-{{ ai_gen_id }} ai-hero-banner-button-secondary-{{ ai_gen_id }}"
          >
            {{ block.settings.button_secondary_label }}
          </a>
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Hero banner",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Desktop background image"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Mobile background image",
      "info": "Optional. If not set, desktop image will be used on mobile."
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 300,
      "max": 800,
      "step": 50,
      "unit": "px",
      "label": "Desktop minimum height",
      "default": 500
    },
    {
      "type": "range",
      "id": "min_height_mobile",
      "min": 200,
      "max": 600,
      "step": 50,
      "unit": "px",
      "label": "Mobile minimum height",
      "default": 400
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 50
    },
    {
      "type": "header",
      "content": "Text box"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 400,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "label": "Maximum width",
      "default": 700
    },
    {
      "type": "color",
      "id": "text_box_background",
      "label": "Background color",
      "default": "rgba(0,0,0,0)"
    },
    {
      "type": "range",
      "id": "text_box_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 0
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Welcome to our store</p>"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 56
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Description"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Discover our latest collection and find your perfect style</p>"
    },
    {
      "type": "range",
      "id": "description_size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Description size",
      "default": 18
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Primary button"
    },
    {
      "type": "text",
      "id": "button_primary_label",
      "label": "Button text",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_primary_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "button_primary_bg",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_primary_color",
      "label": "Text color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "button_primary_hover_bg",
      "label": "Hover background color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "button_primary_hover_color",
      "label": "Hover text color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Secondary button"
    },
    {
      "type": "text",
      "id": "button_secondary_label",
      "label": "Button text",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "button_secondary_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "button_secondary_bg",
      "label": "Background color",
      "default": "rgba(0,0,0,0)"
    },
    {
      "type": "color",
      "id": "button_secondary_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_secondary_hover_bg",
      "label": "Hover background color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_secondary_hover_color",
      "label": "Hover text color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Button style"
    },
    {
      "type": "range",
      "id": "button_text_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Hero banner"
    }
  ]
}
{% endschema %}
