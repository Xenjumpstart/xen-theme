{% doc %}
  @prompt
    Create a hero banner with 4-column feature grid section:
    
    BANNER SECTION:
    - Full-width background with image upload option
    - Orange gradient overlay (customizable color and opacity)
    - Large white H1 heading positioned top-left with bold weight
    - White paragraph text below heading (customizable font size)
    - Right-side product image placement
    - Padding controls for top/bottom spacing
    
    4-COLUMN GRID SECTION:
    - Semi-transparent dark green/teal overlay background (adjustable opacity 0-100%)
    - Background color picker for overlay
    - 4 columns with circular images, each with:
      * Circular image with colored border ring (customizable border color per column)
      * Border width control (2-10px)
      * Separate image upload for DESKTOP and MOBILE versions
      * White bold H3 heading below image
      * White body text below heading
      * Individual text alignment options
    
    RESPONSIVE BEHAVIOR:
    - Desktop: 4-5 columns per row, wraps to new row if more than 5
    - Tablet: 2-3 columns per row
    - Mobile: EXACTLY 2 columns per row, stacks vertically
    
    CUSTOMIZATION SETTINGS - SEPARATE DESKTOP & MOBILE CONTROLS:
    - Banner background image upload (desktop and mobile separate)
    - Banner overlay color and opacity
    - Banner heading and body text (rich text editor)
    - Banner text color picker
    - Column background overlay color and opacity
    - Individual column image uploads (DESKTOP IMAGE and MOBILE IMAGE separate uploads for each column)
    - Individual column border colors (color picker for each)
    - Border width slider
    - DESKTOP heading font size (16-48px)
    - MOBILE heading font size (14-32px)
    - DESKTOP body text font size (12-24px)
    - MOBILE body text font size (10-18px)
    - DESKTOP text color pickers (heading and body separate)
    - MOBILE text color pickers (heading and body separate)
    - Padding controls (top, bottom, left, right)
    - CUSTOM CSS TEXTAREA with syntax highlighting
    - Border radius for images (0-100% for circular effect)
    
    DESIGN SPECIFICATIONS:
    - Default circular images (border-radius: 50%)
    - Colored border rings around each image
    - White text on dark overlay for readability
    - Smooth hover effects on columns (optional scale/lift animation)
    - Consistent spacing between columns (gap: 20-40px adjustable)
    - Center-aligned text within each column
    - Mobile-optimized touch targets
    - Mobile displays exactly 2 columns per row with proper wrapping, can we have options to add more column max 8 
    can also have options to set number of column per row on desktop?, can we have padding spacing around the green transparent background, can we set the feature grid section overlay on the image? 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-feature-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-hero-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding: {{ block.settings.banner_padding_top }}px {{ block.settings.banner_padding_left }}px {{ block.settings.banner_padding_bottom }}px {{ block.settings.banner_padding_right }}px;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    overflow: hidden;
  }

  .ai-hero-banner-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: {{ block.settings.banner_overlay_color }};
    opacity: {{ block.settings.banner_overlay_opacity | divided_by: 100.0 }};
    pointer-events: none;
  }

  .ai-hero-banner-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 40px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-hero-banner-text-{{ ai_gen_id }} {
    flex: 1;
    max-width: 600px;
  }

  .ai-hero-banner-heading-{{ ai_gen_id }} {
    margin: 0 0 20px;
    font-weight: 700;
    color: {{ block.settings.banner_text_color }};
  }

  .ai-hero-banner-heading-{{ ai_gen_id }} h1 {
    margin: 0;
    font-size: {{ block.settings.desktop_heading_size }}px;
    line-height: 1.2;
  }

  .ai-hero-banner-body-{{ ai_gen_id }} {
    color: {{ block.settings.banner_text_color }};
    font-size: {{ block.settings.desktop_body_size }}px;
    line-height: 1.6;
  }

  .ai-hero-banner-image-{{ ai_gen_id }} {
    flex-shrink: 0;
    max-width: 500px;
  }

  .ai-hero-banner-image-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-feature-grid-outer-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .ai-feature-grid-outer-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: {{ block.settings.grid_overlay_color }};
    opacity: {{ block.settings.grid_overlay_opacity | divided_by: 100.0 }};
    pointer-events: none;
  }

  .ai-feature-grid-{{ ai_gen_id }} {
    position: relative;
    z-index: 1;
    padding: {{ block.settings.grid_padding_top }}px {{ block.settings.grid_padding_left }}px {{ block.settings.grid_padding_bottom }}px {{ block.settings.grid_padding_right }}px;
  }

  .ai-feature-grid-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.desktop_columns_per_row }}, 1fr);
    gap: {{ block.settings.column_gap }}px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-feature-column-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: transform 0.3s ease;
  }

  .ai-feature-column-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
  }

  .ai-feature-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    margin-bottom: 20px;
  }

  .ai-feature-image-{{ ai_gen_id }} {
    width: 150px;
    height: 150px;
    border-radius: {{ block.settings.image_border_radius }}%;
    object-fit: cover;
    display: block;
  }

  .ai-feature-heading-{{ ai_gen_id }} {
    margin: 0 0 10px;
    font-weight: 700;
    color: {{ block.settings.desktop_heading_color }};
    font-size: {{ block.settings.desktop_grid_heading_size }}px;
  }

  .ai-feature-heading-{{ ai_gen_id }} h3 {
    margin: 0;
    font-size: inherit;
  }

  .ai-feature-text-{{ ai_gen_id }} {
    color: {{ block.settings.desktop_body_color }};
    font-size: {{ block.settings.desktop_grid_body_size }}px;
    line-height: 1.6;
  }

  .ai-custom-css-{{ ai_gen_id }} {
    {{ block.settings.custom_css }}
  }

  @media screen and (max-width: 989px) {
    .ai-hero-banner-content-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
    }

    .ai-hero-banner-image-{{ ai_gen_id }} {
      max-width: 100%;
    }

    .ai-feature-grid-container-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-hero-banner-heading-{{ ai_gen_id }} h1 {
      font-size: {{ block.settings.mobile_heading_size }}px;
    }

    .ai-hero-banner-body-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_body_size }}px;
    }

    .ai-feature-heading-{{ ai_gen_id }} {
      color: {{ block.settings.mobile_heading_color }};
      font-size: {{ block.settings.mobile_grid_heading_size }}px;
    }

    .ai-feature-text-{{ ai_gen_id }} {
      color: {{ block.settings.mobile_body_color }};
      font-size: {{ block.settings.mobile_grid_body_size }}px;
    }

    .ai-feature-grid-container-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }
{% endstyle %}

<hero-feature-grid-{{ ai_gen_id }} class="ai-hero-feature-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div 
    class="ai-hero-banner-{{ ai_gen_id }}"
    style="background-image: url('{% if block.settings.banner_bg_desktop %}{{ block.settings.banner_bg_desktop | image_url: width: 2000 }}{% endif %}');"
  >
    <div class="ai-hero-banner-content-{{ ai_gen_id }}">
      <div class="ai-hero-banner-text-{{ ai_gen_id }}">
        {% if block.settings.banner_heading != blank %}
          <div class="ai-hero-banner-heading-{{ ai_gen_id }}">
            {{ block.settings.banner_heading }}
          </div>
        {% endif %}
        {% if block.settings.banner_body != blank %}
          <div class="ai-hero-banner-body-{{ ai_gen_id }}">
            {{ block.settings.banner_body }}
          </div>
        {% endif %}
      </div>
      {% if block.settings.banner_product_image %}
        <div class="ai-hero-banner-image-{{ ai_gen_id }}">
          <img 
            src="{{ block.settings.banner_product_image | image_url: width: 1000 }}"
            alt="{{ block.settings.banner_product_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.banner_product_image.width }}"
            height="{{ block.settings.banner_product_image.height }}"
          >
        </div>
      {% endif %}
    </div>
  </div>

  <div 
    class="ai-feature-grid-outer-{{ ai_gen_id }}"
    style="background-image: url('{% if block.settings.grid_bg_desktop %}{{ block.settings.grid_bg_desktop | image_url: width: 2000 }}{% endif %}');"
  >
    <div class="ai-feature-grid-{{ ai_gen_id }}">
      <div class="ai-feature-grid-container-{{ ai_gen_id }}">
        {% for i in (1..8) %}
          {% liquid
            assign column_enabled_key = 'column_' | append: i | append: '_enabled'
            assign desktop_image_key = 'column_' | append: i | append: '_desktop_image'
            assign mobile_image_key = 'column_' | append: i | append: '_mobile_image'
            assign heading_key = 'column_' | append: i | append: '_heading'
            assign text_key = 'column_' | append: i | append: '_text'
            assign border_color_key = 'column_' | append: i | append: '_border_color'
            assign alignment_key = 'column_' | append: i | append: '_alignment'

            assign column_enabled = block.settings[column_enabled_key]
            assign desktop_image = block.settings[desktop_image_key]
            assign mobile_image = block.settings[mobile_image_key]
            assign heading = block.settings[heading_key]
            assign text = block.settings[text_key]
            assign border_color = block.settings[border_color_key]
            assign alignment = block.settings[alignment_key]
          %}

          {% if column_enabled %}
            <div class="ai-feature-column-{{ ai_gen_id }}" style="text-align: {{ alignment }};">
              <div class="ai-feature-image-wrapper-{{ ai_gen_id }}">
                <picture>
                  {% if mobile_image %}
                    <source media="(max-width: 749px)" srcset="{{ mobile_image | image_url: width: 300 }}">
                  {% endif %}
                  {% if desktop_image %}
                    <img 
                      src="{{ desktop_image | image_url: width: 300 }}"
                      alt="{{ desktop_image.alt | escape }}"
                      loading="lazy"
                      class="ai-feature-image-{{ ai_gen_id }}"
                      style="border: {{ block.settings.border_width }}px solid {{ border_color }};"
                    >
                  {% else %}
                    <div class="ai-feature-image-placeholder-{{ ai_gen_id }}">
                      {{ 'image' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </picture>
              </div>
              {% if heading != blank %}
                <div class="ai-feature-heading-{{ ai_gen_id }}">
                  {{ heading }}
                </div>
              {% endif %}
              {% if text != blank %}
                <div class="ai-feature-text-{{ ai_gen_id }}">
                  {{ text }}
                </div>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>

  <div class="ai-custom-css-{{ ai_gen_id }}"></div>
</hero-feature-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class HeroFeatureGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.updateBackgroundImages();
        window.addEventListener('resize', () => this.updateBackgroundImages());
      }

      updateBackgroundImages() {
        const banner = this.querySelector('.ai-hero-banner-{{ ai_gen_id }}');
        const gridOuter = this.querySelector('.ai-feature-grid-outer-{{ ai_gen_id }}');
        const isMobile = window.innerWidth <= 749;
        
        const desktopBannerBg = '{% if block.settings.banner_bg_desktop %}{{ block.settings.banner_bg_desktop | image_url: width: 2000 }}{% endif %}';
        const mobileBannerBg = '{% if block.settings.banner_bg_mobile %}{{ block.settings.banner_bg_mobile | image_url: width: 1000 }}{% endif %}';
        
        const desktopGridBg = '{% if block.settings.grid_bg_desktop %}{{ block.settings.grid_bg_desktop | image_url: width: 2000 }}{% endif %}';
        const mobileGridBg = '{% if block.settings.grid_bg_mobile %}{{ block.settings.grid_bg_mobile | image_url: width: 1000 }}{% endif %}';
        
        if (isMobile && mobileBannerBg) {
          banner.style.backgroundImage = `url('${mobileBannerBg}')`;
        } else if (desktopBannerBg) {
          banner.style.backgroundImage = `url('${desktopBannerBg}')`;
        }

        if (isMobile && mobileGridBg) {
          gridOuter.style.backgroundImage = `url('${mobileGridBg}')`;
        } else if (desktopGridBg) {
          gridOuter.style.backgroundImage = `url('${desktopGridBg}')`;
        }
      }
    }

    customElements.define('hero-feature-grid-{{ ai_gen_id }}', HeroFeatureGrid{{ ai_gen_id }});
  })();
</script>

