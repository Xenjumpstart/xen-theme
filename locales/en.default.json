    "foxify-1738027916oOwzT": {
      "x-8nf65jfk-text_html": "Very smooth paper quality.&nbsp;",
      "x-vi8kh5vd-text_html": "Paper gifts for the people who guide us!",
      "x-dihhng2g-title_html": "Cards",
      "x-yxbacn0h-title_html": "Accessories",
      "x-kjhjj5r5-text_html": "Experiencing new quality notebook.",
      "x-opf7l62j-button_label_html": "View all products",
      "x-wovnp5zd-text_html": "Easy to write and easy to read.",
      "x-8o69e2t9-button_label_html": "Shop now",
      "x-mjnadljd-text_html": "Discover something new",
      "x-txdq1b9u-button_label_html": "View All Products",
      "x-uxt1izvd-press_list-5-title_html": "<p>Paper gifts for the people who guide us. If there is a determination, there is a notebook.</p>",
      "x-uxt1izvd-press_list-2-title_html": "<p>Delivery were very fast. It fits really well and the quality is really good.</p>",
      "x-cq5rby05-button_label_html": "Shop now",
      "x-uxt1izvd-press_list-3-title_html": "<p>Go green and create a new healthy, environment-friendly skincare routine.</p>",
      "x-uxt1izvd-press_list-1-title_html": "<p>We bring the best of cosmetics innovation in terms of efficacy and eco-friendly.</p>",
      "x-uxt1izvd-press_list-4-title_html": "<p>Peaceful state of mind skincare products for a healthy skin &amp; a calming soul.</p>",
      "x-uxt1izvd-press_list-Item-1729129480k5s0m-title_html": "<p>You can add text content from press comments, reviews, or testimonials here.</p>",
      "x-6oh7pl6t-text_html": "Limited time offer",
      "x-iqkasp17-text_html": "Shop before it ends",
      "x-820uuosc-text_html": "Featured collection",
      "x-z9ixoo6w-text_html": "Start discovering an ideal notebook today.",
      "x-2tqppc1c-text_html": "Diaries collection",
      "x-omk14ja7-button_label_html": "View collection",
      "x-ju6v2myq-text_html": "Choose <strong>Stationary</strong> and art materials that make you feel <strong>Excited</strong> to create!",
      "x-jwhpeqg3-text_html": "Paper gifts for you",
      "x-43ruarie-button_label_html": "Shop now",
      "x-ib2oghro-text_html": "Daily Planners",
      "x-955tox79-button_label_html": "View collection",
      "x-zkz8n9q6-button_label_html": "View all",
      "x-9gvdrkni-text_html": "our story",
      "x-2pse567p-text_html": "When you say notebook, we are there.",
      "x-elmzzg0i-text_html": "This store is a demonstration of a luxury brand using the Stiletto Shopify theme. Products and imagery for this demo graciously provided by St. AgniOur.",
      "x-z0rdjw91-button_label_html": "Learn More",
      "x-ri97nj76-text_html": "Discover unique items",
      "x-cu6tqmo0-text_html": "Jennifer C.",
      "x-bhmsce8x-text_html": "Write about your lovely days.",
      "x-c4y0njb7-button_label_html": "View collection",
      "x-wsxw6df9-text_html": "<p>Reviews are in</p>",
      "x-ql0hgswx-testimonial_list-1-bio_html": "Wool beanie",
      "x-ql0hgswx-testimonial_list-1-text_html": "<p>“I wanted a piece of jewelry that would be both classy and unique. I can wear it with any outfit and find myself putting on as soon as I wake up.”</p>",
      "x-ql0hgswx-testimonial_list-1-author_html": "Jenny",
      "x-ql0hgswx-testimonial_list-Item-1729138845k0VpC-bio_html": "Customer",
