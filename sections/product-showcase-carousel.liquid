{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Dynamic Typography and Colors */
  .product-showcase__banner-content h2 {
    font-size: {{ section.settings.banner_heading_size_mobile }}px;
    color: {{ section.settings.banner_text_color }};
  }
  .product-showcase__banner-content p {
    font-size: {{ section.settings.banner_subheading_size_mobile }}px;
    color: {{ section.settings.banner_text_color }};
  }

  @media screen and (min-width: 750px) {
    .product-showcase__banner-content h2 {
      font-size: {{ section.settings.banner_heading_size }}px;
    }
    .product-showcase__banner-content p {
      font-size: {{ section.settings.banner_subheading_size }}px;
    }
  }

  .product-showcase__title {
    font-size: {{ section.settings.product_title_size }}px !important;
    color: {{ section.settings.product_text_color }} !important;
  }
  .product-showcase__price {
    font-size: {{ section.settings.product_price_size }}px !important;
    color: {{ section.settings.product_price_color }} !important;
  }
{%- endstyle -%}

<div class="product-showcase section-{{ section.id }}-padding page-width">
  
  {%- if section.settings.show_banner -%}
    <div class="product-showcase__banner">
      <div class="product-showcase__banner-media">
        {%- if section.settings.banner_video != blank -%}
          {{ section.settings.banner_video | video_tag: autoplay: true, loop: true, muted: true, controls: false }}
        {%- elsif section.settings.banner_image != blank -%}
          <img src="{{ section.settings.banner_image | image_url: width: 1500 }}" alt="{{ section.settings.banner_image.alt }}" loading="lazy">
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
      <div class="product-showcase__banner-overlay" style="background: rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }});"></div>
      <div class="product-showcase__banner-content">
        <h2 class="h1">{{ section.settings.banner_heading }}</h2>
        <p>{{ section.settings.banner_subheading }}</p>
      </div>
    </div>
  {%- endif -%}

  <slider-component class="product-showcase__slider-wrapper">
    <ul id="Slider-{{ section.id }}" class="product-showcase__slider list-unstyled slider--mobile" role="list">
      {%- for block in section.blocks -%}
        <li id="Slide-{{ section.id }}-{{ forloop.index }}" class="product-showcase__item slider__slide" {{ block.shopify_attributes }}>
          {%- assign product = block.settings.product -%}
          <a href="{{ product.url | default: '#' }}" class="product-showcase__info">
            <div class="product-showcase__media-card">
              {%- if block.settings.video != blank -%}
                {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false }}
              {%- elsif block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.image.alt }}" loading="lazy">
              {%- elsif product.featured_media != blank -%}
                 <img src="{{ product.featured_media | image_url: width: 600 }}" alt="{{ product.title }}" loading="lazy">
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
            <h3 class="product-showcase__title">{{ product.title | default: "Example Product" }}</h3>
            <div class="product-showcase__price">
              {%- if product != blank -%}
                {{ product.price | money }}
              {%- else -%}
                $19.99
              {%- endif -%}
            </div>
          </a>
        </li>
      {%- endfor -%}
    </ul>
  </slider-component>

</div>

{% schema %}
{
  "name": "Product Showcase Carousel",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Banner Styling"
    },
    {
      "type": "checkbox",
      "id": "show_banner",
      "default": true,
      "label": "Show Top Banner"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner Image"
    },
    {
      "type": "video",
      "id": "banner_video",
      "label": "Banner Video"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "%",
      "label": "Overlay Opacity",
      "default": 30
    },
    {
      "type": "inline_richtext",
      "id": "banner_heading",
      "default": "The Collection Story",
      "label": "Banner Heading"
    },
    {
      "type": "range",
      "id": "banner_heading_size",
      "min": 20,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Heading Font Size (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "banner_heading_size_mobile",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Heading Font Size (Mobile)",
      "default": 28
    },
    {
      "type": "inline_richtext",
      "id": "banner_subheading",
      "default": "Explain why your products are the best here.",
      "label": "Banner Subheading"
    },
    {
      "type": "range",
      "id": "banner_subheading_size",
      "min": 12,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Subheading Font Size (Desktop)",
      "default": 18
    },
    {
      "type": "range",
      "id": "banner_subheading_size_mobile",
      "min": 10,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Subheading Font Size (Mobile)",
      "default": 16
    },
    {
      "type": "color",
      "id": "banner_text_color",
      "default": "#FFFFFF",
      "label": "Banner Text Color"
    },
    {
      "type": "header",
      "content": "Product Carousel Styling"
    },
    {
      "type": "color",
      "id": "product_text_color",
      "default": "#121212",
      "label": "Product Title Color"
    },
    {
      "type": "range",
      "id": "product_title_size",
      "min": 10,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Product Title Font Size",
      "default": 14
    },
    {
      "type": "color",
      "id": "product_price_color",
      "default": "#616161",
      "label": "Product Price Color"
    },
    {
      "type": "range",
      "id": "product_price_size",
      "min": 10,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Product Price Font Size",
      "default": 12
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "product_item",
      "name": "Product Item",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        },
        {
          "type": "header",
          "content": "Override Media (Optional)"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom Image"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Custom Video"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Showcase Carousel",
      "blocks": [
        { "type": "product_item" },
        { "type": "product_item" },
        { "type": "product_item" },
        { "type": "product_item" },
        { "type": "product_item" }
      ]
    }
  ]
}
{% endschema %}
