{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-slideshow.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .modern-carousel-{{ section.id }} {
    --carousel-height: {{ section.settings.desktop_height }}px;
  }

  @media screen and (max-width: 749px) {
    .modern-carousel-{{ section.id }} {
      --carousel-height: {{ section.settings.mobile_height }}px;
    }
  }

  .modern-carousel__slide {
    display: flex !important;
    flex-direction: row;
    height: var(--carousel-height);
    background: {{ section.settings.bg_color }};
  }

  .modern-carousel__slide.flex-reverse {
    flex-direction: row-reverse;
  }

  .modern-carousel__media {
    flex: 0 0 50%;
    position: relative;
    overflow: hidden;
  }

  .modern-carousel__content {
    flex: 0 0 50%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 5rem;
    background: {{ section.settings.content_bg }};
  }

  .modern-carousel__media video,
  .modern-carousel__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    top: 0;
    left: 0;
  }

  .modern-carousel__heading {
    font-size: 4.5rem;
    line-height: 1.1;
    margin-bottom: 2rem;
    font-weight: 600;
  }

  .modern-carousel__subheading {
    font-size: 1.2rem;
    margin-bottom: 3rem;
    max-width: 450px;
  }

  @media screen and (max-width: 749px) {
    .modern-carousel-{{ section.id }} {
      --carousel-height: {{ section.settings.mobile_height }}px;
    }
    .modern-carousel__slide {
      flex-direction: column !important;
      position: relative;
      height: var(--carousel-height);
    }
    .modern-carousel__media {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 1;
    }
    .modern-carousel__content {
      position: relative;
      z-index: 2;
      background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.4) 40%, transparent 100%) !important;
      height: 100%;
      justify-content: flex-end !important;
      padding: 3rem 2rem !important;
      width: 100% !important;
      color: #FFFFFF !important;
    }
    .modern-carousel__heading {
      font-size: 2.8rem !important;
      margin-bottom: 1rem !important;
    }
    .modern-carousel__subheading {
      font-size: 1.1rem !important;
      margin-bottom: 2rem !important;
    }
    .modern-carousel__content .button {
      width: 100%;
    }
  }
{%- endstyle -%}

<slideshow-component class="modern-carousel-{{ section.id }} slider-mobile-gutter" role="region" aria-roledescription="Carousel">
  <div class="slideshow slider slider--everywhere" id="Slider-{{ section.id }}" aria-live="polite">
    {%- for block in section.blocks -%}
      <div class="modern-carousel__slide slider__slide {% if block.settings.layout == 'text_first' %} flex-reverse{% endif %}" id="Slide-{{ section.id }}-{{ forloop.index }}" {{ block.shopify_attributes }}>
        
        <div class="modern-carousel__media">
          {%- if block.type == 'video' -%}
            {%- if block.settings.video != blank -%}
              {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false }}
            {%- endif -%}
          {%- else -%}
             {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 1000 }}" alt="{{ block.settings.image.alt | escape }}" loading="lazy">
            {%- else -%}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          {%- endif -%}
        </div>

        <div class="modern-carousel__content color-{{ block.settings.color_scheme }}">
          {%- if block.settings.heading != blank -%}
            <h2 class="modern-carousel__heading">{{ block.settings.heading }}</h2>
          {%- endif -%}
          {%- if block.settings.subheading != blank -%}
            <div class="modern-carousel__subheading rte">{{ block.settings.subheading }}</div>
          {%- endif -%}
          {%- if block.settings.button_label != blank -%}
            <div class="banner__buttons">
              <a {% if block.settings.link %} href="{{ block.settings.link }}"{% else %} role="link" aria-disabled="true"{% endif %} class="button button--primary">{{ block.settings.button_label | escape }}</a>
            </div>
          {%- endif -%}
        </div>

      </div>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    <div class="slideshow__controls slider-buttons no-js-hidden">
      <button type="button" class="slider-button slider-button--prev" name="previous" aria-label="Previous">
        <span class="svg-wrapper"><svg viewBox="0 0 10 6" class="icon icon-caret"><path d="M9.354.646a.5.5 0 00-.708 0L5 4.293 1.354.646a.5.5 0 00-.708.708l4 4a.5.5 0 00.708 0l4-4a.5.5 0 000-.708z" fill="currentColor"></svg></span>
      </button>
      <div class="slider-counter slider-counter--dots">
        <div class="slideshow__control-wrapper">
          {%- for block in section.blocks -%}
            <button class="slider-counter__link slider-counter__link--dots link" aria-label="Load slide {{ forloop.index }}">
              <span class="dot"></span>
            </button>
          {%- endfor -%}
        </div>
      </div>
      <button type="button" class="slider-button slider-button--next" name="next" aria-label="Next">
        <span class="svg-wrapper"><svg viewBox="0 0 10 6" class="icon icon-caret"><path d="M9.354.646a.5.5 0 00-.708 0L5 4.293 1.354.646a.5.5 0 00-.708.708l4 4a.5.5 0 00.708 0l4-4a.5.5 0 000-.708z" fill="currentColor"></svg></span>
      </button>
    </div>
  {%- endif -%}
</slideshow-component>

{% schema %}
{
  "name": "Modern Split Carousel",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "range", "id": "desktop_height", "min": 400, "max": 800, "step": 50, "unit": "px", "label": "Desktop Height", "default": 600 },
    { "type": "range", "id": "mobile_height", "min": 300, "max": 600, "step": 50, "unit": "px", "label": "Mobile Height", "default": 500 }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "select", "id": "layout", "options": [
          { "value": "image_first", "label": "Image Left" },
          { "value": "text_first", "label": "Image Right" }
        ], "default": "image_first", "label": "Desktop Layout" },
        { "type": "inline_richtext", "id": "heading", "default": "Elevate Your Style", "label": "Heading" },
        { "type": "richtext", "id": "subheading", "default": "<p>Discover our curated collection of premium essentials.</p>", "label": "Subheading" },
        { "type": "text", "id": "button_label", "default": "Shop Now", "label": "Button Label" },
        { "type": "url", "id": "link", "label": "Button Link" },
        { "type": "color_scheme", "id": "color_scheme", "label": "Color Scheme", "default": "scheme-1" }
      ]
    },
    {
      "type": "video",
      "name": "Video Slide",
      "settings": [
        { "type": "video", "id": "video", "label": "Shopify Video" },
        { "type": "select", "id": "layout", "options": [
          { "value": "image_first", "label": "Video Left" },
          { "value": "text_first", "label": "Video Right" }
        ], "default": "image_first", "label": "Desktop Layout" },
        { "type": "inline_richtext", "id": "heading", "default": "Motion in Style", "label": "Heading" },
        { "type": "richtext", "id": "subheading", "default": "<p>Experience our products in action.</p>", "label": "Subheading" },
        { "type": "text", "id": "button_label", "default": "Watch & Shop", "label": "Button Label" },
        { "type": "url", "id": "link", "label": "Button Link" },
        { "type": "color_scheme", "id": "color_scheme", "label": "Color Scheme", "default": "scheme-1" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Modern Split Carousel",
      "blocks": [{ "type": "image" }, { "type": "video" }]
    }
  ]
}
{% endschema %}
