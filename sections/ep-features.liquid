
<div class="ep-wrap">
  <section class="ep-features">
    <div class="ep-features-inner">
      <div class="ep-features-header">
        <div class="ep-feat-eyebrow ep-reveal">
          <div class="ep-feat-eyebrow-bar">&nbsp;</div>
          <span>{{ section.settings.eyebrow }}</span>
          <div class="ep-feat-eyebrow-bar">&nbsp;</div>
        </div>
        <h2 class="ep-feat-title ep-reveal ep-d1">
          {{ section.settings.heading }}
        </h2>
      </div>

      <div class="ep-feat-grid">
        {% for block in section.blocks %}
          <div class="ep-feat-item ep-reveal ep-d{{ forloop.index0 }}">
            <div class="ep-feat-icon">
              {{ block.settings.svg_icon }}
            </div>
            <div class="ep-feat-rule">&nbsp;</div>
            <div class="ep-feat-name">{{ block.settings.title }}</div>
            <p class="ep-feat-desc">{{ block.settings.description }}</p>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Features",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Why Motion Series"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Built to a standard<br>you can <em>feel</em></p>"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "html", "id": "svg_icon", "label": "SVG Icon" },
        { "type": "richtext", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "description", "label": "Description" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Features",
      "blocks": [
        { 
          "type": "feature", 
          "settings": { 
            "svg_icon": "<svg viewBox=\"0 0 44 44\" fill=\"none\"><circle cx=\"22\" cy=\"22\" r=\"14\" stroke=\"#c4953a\" stroke-width=\"1\"/><path d=\"M22 12v10l6 4\" stroke=\"#c4953a\" stroke-width=\"1.2\" stroke-linecap=\"round\"/><circle cx=\"22\" cy=\"22\" r=\"2\" fill=\"#c4953a\"/></svg>",
            "title": "<p>Precision<br><em>Engineering</em></p>",
            "description": "Calibrated to micrometric tolerances, ensuring consistent performance across ten thousand cycles."
          } 
        },
        { 
          "type": "feature", 
          "settings": { 
            "svg_icon": "<svg viewBox=\"0 0 44 44\" fill=\"none\"><path d=\"M8 22c0-7.732 6.268-14 14-14s14 6.268 14 14\" stroke=\"#c4953a\" stroke-width=\"1\" stroke-linecap=\"round\"/><path d=\"M14 26c0 4.418 3.582 8 8 8s8-3.582 8-8\" stroke=\"#c4953a\" stroke-width=\"1\" stroke-linecap=\"round\"/><line x1=\"22\" y1=\"18\" x2=\"22\" y2=\"30\" stroke=\"#c4953a\" stroke-width=\"1.2\" stroke-linecap=\"round\"/></svg>",
            "title": "<p>Silent<br><em>Motion</em></p>",
            "description": "German-engineered soft-close damping technology — motion heard only in its absence."
          } 
