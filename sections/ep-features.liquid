        { 
          "type": "feature", 
          "settings": { 
            "svg_icon": "<svg viewBox=\"0 0 44 44\" fill=\"none\"><rect x=\"10\" y=\"14\" width=\"24\" height=\"16\" rx=\"1\" stroke=\"#c4953a\" stroke-width=\"1\"/><path d=\"M16 22h12M22 18v8\" stroke=\"#c4953a\" stroke-width=\"1.2\" stroke-linecap=\"round\"/><path d=\"M10 30l4 4h16l4-4\" stroke=\"#c4953a\" stroke-width=\"1\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>",
            "title": "<p>Durability<br><em>Tested</em></p>",
            "description": "Aerospace aluminium alloy construction with 10-year motor warranties. Built for decades, not seasons."
          } 
        },
        { 
          "type": "feature", 
          "settings": { 
            "svg_icon": "<svg viewBox=\"0 0 44 44\" fill=\"none\"><path d=\"M22 8l2.6 8h8.4l-6.8 4.9 2.6 8L22 24l-6.8 4.9 2.6-8L11 16h8.4z\" stroke=\"#c4953a\" stroke-width=\"1\" stroke-linejoin=\"round\"/><circle cx=\"22\" cy=\"30\" r=\"5\" stroke=\"#c4953a\" stroke-width=\"1\"/></svg>",
            "title": "<p>Premium<br><em>Materials</em></p>",
            "description": "Matte-finish aluminium alloy, tempered glass, Italian-lacquered components. A standard felt before it is seen."
