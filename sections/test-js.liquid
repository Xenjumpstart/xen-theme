{% comment %}
  This is a recreation of a complex section with many utility classes.
  The styling is reverse-engineered from these class names.
  The original HTML structure is maintained as closely as possible.
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    --color-background: {{ section.settings.background_color }};
    --color-text: {{ section.settings.text_color }};
    --color-button-background: {{ section.settings.button_bg_color }};
    --color-button-text: {{ section.settings.button_text_color }};
    --color-link: {{ section.settings.link_color }};
    --color-link-hover: {{ section.settings.link_hover_color }};

    background-color: var(--color-background);
    color: var(--color-text);
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #shopify-section-{{ section.id }} .relative { position: relative; }
  #shopify-section-{{ section.id }} .absolute { position: absolute; }
  #shopify-section-{{ section.id }} .sticky { position: sticky; }
  #shopify-section-{{ section.id }} .outline-none { outline: none; }
  #shopify-section-{{ section.id }} .top-0 { top: 0; }
  #shopify-section-{{ section.id }} .left-0 { left: 0; }
  #shopify-section-{{ section.id }} .inset-0 { top: 0; right: 0; bottom: 0; left: 0; }
  #shopify-section-{{ section.id }} .z-0 { z-index: 0; }
  #shopify-section-{{ section.id }} .z-1 { z-index: 1; }
  #shopify-section-{{ section.id }} .isolate { isolation: isolate; }
  #shopify-section-{{ section.id }} .w-full { width: 100%; }
  #shopify-section-{{ section.id }} .h-full { height: 100%; }
  #shopify-section-{{ section.id }} .size-full { width: 100%; height: 100%; }
  #shopify-section-{{ section.id }} .min-h-\[100svh\] { min-height: 100svh; }
  #shopify-section-{{ section.id }} .overflow-hidden { overflow: hidden; }
  #shopify-section-{{ section.id }} .overflow-clip { overflow: clip; }
  #shopify-section-{{ section.id }} .pointer-events-none { pointer-events: none; }
  #shopify-section-{{ section.id }} .pointer-events-auto { pointer-events: auto; }
  #shopify-section-{{ section.id }} .mx-auto { margin-left: auto; margin-right: auto; }
  #shopify-section-{{ section.id }} .block { display: block; }
  #shopify-section-{{ section.id }} .flex { display: flex; }
  #shopify-section-{{ section.id }} .grid { display: grid; }
  #shopify-section-{{ section.id }} .flex-col { flex-direction: column; }
  #shopify-section-{{ section.id }} .flex-wrap { flex-wrap: wrap; }
  #shopify-section-{{ section.id }} .items-center { align-items: center; }
  #shopify-section-{{ section.id }} .content-start { align-content: flex-start; }
  #shopify-section-{{ section.id }} .place-items-center { place-items: center; }
  #shopify-section-{{ section.id }} .self-start { align-self: flex-start; }
  #shopify-section-{{ section.id }} .box-border { box-sizing: border-box; }
  #shopify-section-{{ section.id }} .order-2 { order: 2; }
  #shopify-section-{{ section.id }} .object-cover { object-fit: cover; }
  #shopify-section-{{ section.id }} .transition-opacity { transition-property: opacity; transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1); }
  #shopify-section-{{ section.id }} .duration-200 { transition-duration: 200ms; }
  #shopify-section-{{ section.id }} .duration-300 { transition-duration: 300ms; }
  #shopify-section-{{ section.id }} .opacity-0 { opacity: 0; }
  #shopify-section-{{ section.id }} .opacity-100 { opacity: 1; }
  #shopify-section-{{ section.id }} .invisible { visibility: hidden; }
  #shopify-section-{{ section.id }} .max-w-content-lg { max-width: 1440px; }
  #shopify-section-{{ section.id }} .px-16 { padding-left: 16px; padding-right: 16px; }
  #shopify-section-{{ section.id }} .py-7 { padding-top: 7px; padding-bottom: 7px; }
  #shopify-section-{{ section.id }} .px-8 { padding-left: 8px; padding-right: 8px; }
  #shopify-section-{{ section.id }} .pb-32 { padding-bottom: 32px; }
  #shopify-section-{{ section.id }} .pt-20 { padding-top: 20px; }
  #shopify-section-{{ section.id }} .pt-24 { padding-top: 24px; }
  #shopify-section-{{ section.id }} .pt-52 { padding-top: 52px; }
  #shopify-section-{{ section.id }} .pb-64 { padding-bottom: 64px; }
  #shopify-section-{{ section.id }} .py-100 { padding-top: 100px; padding-bottom: 100px; }
  #shopify-section-{{ section.id }} .mt-2 { margin-top: 2px; }
  #shopify-section-{{ section.id }} .mt-24 { margin-top: 24px; }
  #shopify-section-{{ section.id }} .mb-24 { margin-bottom: 24px; }
  #shopify-section-{{ section.id }} .mt-40 { margin-top: 40px; }
  #shopify-section-{{ section.id }} .gap-16 { gap: 16px; }
  #shopify-section-{{ section.id }} .gap-20 { gap: 20px; }
  #shopify-section-{{ section.id }} .gap-40 { gap: 40px; }
  #shopify-section-{{ section.id }} .gap-y-12 { row-gap: 12px; }
  #shopify-section-{{ section.id }} .gap-y-16 { row-gap: 16px; }
  #shopify-section-{{ section.id }} .gap-y-44 { row-gap: 44px; }
  #shopify-section-{{ section.id }} .gap-x-grid-gutter { column-gap: 20px; }
  #shopify-section-{{ section.id }} .text-left { text-align: left; }
  #shopify-section-{{ section.id }} .text-w70 { color: rgba(255, 255, 255, 0.7); }
  #shopify-section-{{ section.id }} .text-w100 { color: var(--color-text); }
  #shopify-section-{{ section.id }} .text-white { color: #fff; }
  #shopify-section-{{ section.id }} h2.t2 { font-size: clamp(2.5rem, 1.35rem + 5.75vw, 6rem); line-height: 1; font-weight: 500; }
  #shopify-section-{{ section.id }} .t3 { font-size: clamp(1.5rem, 1.05rem + 2.25vw, 2.75rem); line-height: 1.1; font-weight: 500; }
  #shopify-section-{{ section.id }} h3.t4 { font-size: clamp(1rem, 0.825rem + 0.875vw, 1.5rem); line-height: 1.2; font-weight: 500; }
  #shopify-section-{{ section.id }} .t5 { font-size: clamp(0.875rem, 0.8125rem + 0.3125vw, 1.0625rem); line-height: 1.5; font-weight: 400; }
  #shopify-section-{{ section.id }} .grid-cols-6 { grid-template-columns: repeat(6, minmax(0, 1fr)); }
  #shopify-section-{{ section.id }} .col-span-6 { grid-column: span 6 / span 6; }
  #shopify-section-{{ section.id }} .col-span-full { grid-column: 1 / -1; }
  #shopify-section-{{ section.id }} .grid-cols-subgrid { grid-template-columns: subgrid; }
  #shopify-section-{{ section.id }} .min-h-\[1lh\] { min-height: 1lh; min-height: 1.5rem; }
  #shopify-section-{{ section.id }} .last\:pb-0 > :last-child { padding-bottom: 0px; }
  #shopify-section-{{ section.id }} .aspect-4\/3 { aspect-ratio: 4 / 3; }
  #shopify-section-{{ section.id }} .content-container { width: 100%; max-width: 1440px; margin-left: auto; margin-right: auto; padding-left: 16px; padding-right: 16px; }
  #shopify-section-{{ section.id }} .link-underline { text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 4px; }
  #shopify-section-{{ section.id }} a { color: var(--color-link); transition: color 0.2s ease; }
  #shopify-section-{{ section.id }} a:hover { color: var(--color-link-hover); }
  #shopify-section-{{ section.id }} .button-small { font-size: 0.875rem; line-height: 1.25rem; font-weight: 500; text-decoration: none; }
  #shopify-section-{{ section.id }} .rounded-full { border-radius: 9999px; }
  #shopify-section-{{ section.id }} .bg-theme-cta-bg { background-color: var(--color-button-background); }
  #shopify-section-{{ section.id }} .text-theme-cta-text { color: var(--color-button-text); }
  #shopify-section-{{ section.id }} a.bg-theme-cta-bg:hover { background-color: var(--color-button-background); opacity: 0.8; }
  #shopify-section-{{ section.id }} .transition-colors { transition-property: color, background-color, border-color, text-decoration-color, fill, stroke; transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1); transition-duration: 150ms; }
  #shopify-section-{{ section.id }} [hidden] { display: none !important; }

  @media (min-width: 640px) {
    #shopify-section-{{ section.id }} .sm\:px-30 { padding-left: 30px; padding-right: 30px; }
    #shopify-section-{{ section.id }} .sm\:px-32 { padding-left: 32px; padding-right: 32px; }
    #shopify-section-{{ section.id }} .sm\:mt-40 { margin-top: 40px; }
    #shopify-section-{{ section.id }} .sm\:mb-56 { margin-bottom: 56px; }
    #shopify-section-{{ section.id }} .sm\:pb-32 { padding-bottom: 32px; }
    #shopify-section-{{ section.id }} .sm\:pb-64 { padding-bottom: 64px; }
    #shopify-section-{{ section.id }} .sm\:gap-x-grid-gutter-sm { column-gap: 32px; }
    #shopify-section-{{ section.id }} .sm\:col-span-3 { grid-column: span 3 / span 3; }
    #shopify-section-{{ section.id }} .sm\:col-span-5 { grid-column: span 5 / span 5; }
    #shopify-section-{{ section.id }} .sm\:max-w-content-lg { max-width: 1440px; }
    #shopify-section-{{ section.id }} .sm\:aspect-\[var\(--media-aspect\)\] { aspect-ratio: var(--media-aspect); }
  }
  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .md\:px-32 { padding-left: 32px; padding-right: 32px; }
    #shopify-section-{{ section.id }} .md\:py-48 { padding-top: 48px; padding-bottom: 48px; }
    #shopify-section-{{ section.id }} .md\:mt-56 { margin-top: 56px; }
    #shopify-section-{{ section.id }} .md\:mb-56 { margin-bottom: 56px; }
    #shopify-section-{{ section.id }} .md\:pb-0 { padding-bottom: 0px; }
    #shopify-section-{{ section.id }} .md\:pb-56 { padding-bottom: 56px; }
    #shopify-section-{{ section.id }} .md\:pb-96 { padding-bottom: 96px; }
    #shopify-section-{{ section.id }} .md\:pt-12 { padding-top: 12px; }
    #shopify-section-{{ section.id }} .md\:gap-x-grid-gutter-sm { column-gap: 32px; }
    #shopify-section-{{ section.id }} .md\:gap-y-40 { row-gap: 40px; }
    #shopify-section-{{ section.id }} .md\:grid-cols-12 { grid-template-columns: repeat(12, minmax(0, 1fr)); }
    #shopify-section-{{ section.id }} .md\:col-span-4 { grid-column: span 4 / span 4; }
    #shopify-section-{{ section.id }} .md\:col-span-5 { grid-column: span 5 / span 5; }
    #shopify-section-{{ section.id }} .md\:col-span-7 { grid-column: span 7 / span 7; }
    #shopify-section-{{ section.id }} .md\:col-span-9 { grid-column: span 9 / span 9; }
    #shopify-section-{{ section.id }} .md\:col-start-8 { grid-column-start: 8; }
  }
  @media (min-width: 1024px) {
    #shopify-section-{{ section.id }} h2.lg\:t1 { font-size: clamp(4rem, 2.3rem + 8.5vw, 9rem); }
    #shopify-section-{{ section.id }} .lg\:mt-64 { margin-top: 64px; }
    #shopify-section-{{ section.id }} .lg\:col-span-4 { grid-column: span 4 / span 4; }
    #shopify-section-{{ section.id }} .lg\:col-start-9 { grid-column-start: 9; }
  }
  @media (min-width: 1280px) {
    #shopify-section-{{ section.id }} .xl\:max-w-content { max-width: 1760px; }
    #shopify-section-{{ section.id }} .xl\:mt-64 { margin-top: 64px; }
    #shopify-section-{{ section.id }} .xl\:col-span-3 { grid-column: span 3 / span 3; }
    #shopify-section-{{ section.id }} .xl\:col-span-5 { grid-column: span 5 / span 5; }
    #shopify-section-{{ section.id }} .xl\:col-start-10 { grid-column-start: 10; }
  }
</style>

<div class="relative isolate z-1 text-white pointer-events-auto">
  <svg aria-hidden="true" class="absolute top-0 left-0 z-0 pointer-events-none" width="1905" height="3656" viewBox="0 0 1905 3656">
      <path d="M0,0 H1905 V3656 H0 Z M112.5,222 h1680 v945 h-1680 Z M112.5,1223 h538.65625 v404 h-538.65625 Z M683.15625,1223 h538.671875 v404 h-538.671875 Z M1253.828125,1223 h538.65625 v404 h-538.65625 Z M112.5,1733.5625 h538.65625 v404 h-538.65625 Z M683.15625,1733.5625 h538.671875 v404 h-538.671875 Z M1253.828125,1733.5625 h538.65625 v404 h-538.65625 Z M112.5,2836.1875 h538.65625 v404 h-538.65625 Z M683.15625,2836.1875 h538.671875 v404 h-538.671875 Z M1253.828125,2836.1875 h538.65625 v404 h-538.65625 Z" fill="{{ section.settings.background_color }}" fill-rule="evenodd"></path>
  </svg>
  <div class="relative z-1">
    <div class="content-container py-100">
      {% if section.settings.heading != blank %}
        <h2 class="t2 lg:t1 text-w100 text-left">{{ section.settings.heading }}</h2>
      {% endif %}
    </div>
    <div class="pb-64 md:pb-96">
      <div class="last:pb-0">
        <section class="relative pt-24">
          <div class="pb-0 sm:pb-32 md:pb-56 mb-24 sm:mb-56">
            <div class="flex flex-col">
              <div class="flex flex-col gap-40">
                {% if section.settings.featured_heading != blank or section.settings.featured_image != blank %}
                  <article class="flex flex-col col-span-full">
                    <div class="order-2 w-full mx-auto sm:max-w-content-lg xl:max-w-content sm:px-32">
                      <div class="media-wrapper relative overflow-hidden aspect-4/3 grid place-items-center sm:aspect-[var(--media-aspect)]" style="--media-aspect:16 / 9">
                          {% if section.settings.featured_image != blank %}
                            {{ section.settings.featured_image | image_url: width: 2720 | image_tag: 
                              loading: 'lazy',
                              class: 'size-full object-cover absolute top-0 left-0',
                              sizes: '100vw',
                              widths: '400, 600, 800, 1000, 1200, 1400, 1600, 1800, 2000, 2400, 2720'
                            }}
                          {% else %}
                            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                          {% endif %}
                      </div>
                    </div>
                    <div class="gap-y-12 content-container grid grid-cols-1 md:grid-cols-12 gap-x-grid-gutter md:gap-x-grid-gutter-sm md:py-48 pb-32 pt-52">
                      {% if section.settings.featured_heading != blank %}
                        <h3 class="t3 md:col-span-7 xl:col-span-5 text-w100">{{ section.settings.featured_heading }}</h3>
                      {% endif %}
                      <div class="flex flex-col gap-20 md:pt-12 md:col-span-5 md:col-start-8 lg:col-span-4 lg:col-start-9 xl:col-span-3 xl:col-start-10 pt-20">
                          {% if section.settings.featured_text != blank %}
                            <div class="rich-text t5">{{ section.settings.featured_text }}</div>
                          {% endif %}
                          {% if section.settings.featured_button_label != blank or section.settings.featured_link_label != blank %}
                            <div class="flex flex-wrap items-center gap-16">
                                {% if section.settings.featured_button_label != blank %}
                                    <a target="_blank" rel="noopener noreferrer" class="bg-theme-cta-bg text-theme-cta-text hover:bg-theme-cta-bg-hover rounded-full outline-none transition-colors button-small px-8 py-7 self-start" href="{{ section.settings.featured_button_url | default: '#' }}">{{ section.settings.featured_button_label }}</a>
                                {% endif %}
                                {% if section.settings.featured_link_label != blank %}
                                    <a target="_blank" rel="noopener noreferrer" class="t5 text-theme-link link-underline outline-none self-start mt-2" href="{{ section.settings.featured_link_url | default: '#' }}">{{ section.settings.featured_link_label }}</a>
                                {% endif %}
                            </div>
                          {% endif %}
                      </div>
                    </div>
                  </article>
                {% endif %}
              </div>
              
              {% if section.blocks.size > 0 %}
                <div class="content-container md:pb-0 mt-40 md:mt-56 pb-32 sm:pb-64">
                  <div class="grid grid-cols-6 md:grid-cols-12 gap-x-grid-gutter sm:gap-x-grid-gutter-sm gap-y-44 md:gap-y-40">
                      {% for block in section.blocks %}
                        <article class="grid grid-cols-subgrid content-start gap-y-16 col-span-6 sm:col-span-3 md:col-span-4" {{ block.shopify_attributes }}>
                            <div class="col-span-full">
                                <div class="media-wrapper relative overflow-hidden aspect-4/3">
                                  {% if block.settings.image != blank %}
                                    {{ block.settings.image | image_url: width: 560 | image_tag: 
                                      loading: 'lazy',
                                      class: 'w-full h-full object-cover',
                                      sizes: '(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw',
                                      widths: '200, 300, 400, 500, 600, 700'
                                    }}
                                  {% else %}
                                    {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                                  {% endif %}
                                </div>
                            </div>
                            <div class="col-span-full flex flex-col gap-y-12">
                                {% if block.settings.heading != blank %}
                                    <h3 class="t4 text-w100">{{ block.settings.heading }}</h3>
                                {% endif %}
                                {% if block.settings.text != blank %}
                                    <div class="rich-text t5">{{ block.settings.text }}</div>
                                {% endif %}
                            </div>
                        </article>
                      {% endfor %}
                  </div>
                </div>
              {% endif %}
            </div>
          </div>
        </section>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Online Features",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Online"
    },
    {
      "type": "header",
      "content": "Featured Item"
    },
    {
      "type": "image_picker",
      "id": "featured_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "featured_heading",
      "label": "Heading",
      "default": "Your AI sales associate"
    },
    {
      "type": "richtext",
      "id": "featured_text",
      "label": "Text",
      "default": "<p>Enter content here</p>"
    },
    {
      "type": "text",
      "id": "featured_button_label",
      "label": "Button Label",
      "default": "Get Shopify Inbox"
    },
    {
      "type": "url",
      "id": "featured_button_url",
      "label": "Button URL"
    },
    {
      "type": "text",
      "id": "featured_link_label",
      "label": "Link Label",
      "default": "Explore AI messaging apps"
    },
    {
      "type": "url",
      "id": "featured_link_url",
      "label": "Link URL"
    },
    {
      "type": "header",
      "content": "Section Styling"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#090909"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text",
      "default": "#090909"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link Color",
      "default": "#BBBBBB"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Link Hover Color",
      "default": "#FFFFFF"
    },
    {
