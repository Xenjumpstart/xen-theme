{%- liquid
  assign heading_text = section.settings.heading | default: "Everywhere"
  assign letters = heading_text | split: ""
  assign num_letters = letters | size
  if num_letters == 0
    assign num_letters = 1
  endif
  assign angle_increment = section.settings.spread_angle | divided_by: num_letters
-%}

<style>
  #shopify-section-{{ section.id }} {
    --text-color: {{ section.settings.text_color }};
    --gradient-color: {{ section.settings.gradient_color }};
    --gradient-height: {{ section.settings.gradient_height }}%;
    --hero-ring-radius: {{ section.settings.ring_radius }}vmin;

    position: relative;
    height: {{ section.settings.section_height }}vh;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.background_color }};
  }
  
  #shopify-section-{{ section.id }} .hero-wrapper {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .relative { position: relative; }
  #shopify-section-{{ section.id }} .absolute { position: absolute; }
  #shopify-section-{{ section.id }} .fixed { position: fixed; }
  #shopify-section-{{ section.id }} .inset-x-0 { left: 0; right: 0; }
  #shopify-section-{{ section.id }} .top-200 { top: 200px; }
  #shopify-section-{{ section.id }} .bottom-0 { bottom: 0; }
  #shopify-section-{{ section.id }} .left-1\/2 { left: 50%; }
  #shopify-section-{{ section.id }} .top-1\/2 { top: 50%; }
  #shopify-section-{{ section.id }} .h-px { height: 1px; }
  #shopify-section-{{ section.id }} .w-px { width: 1px; }
  #shopify-section-{{ section.id }} .h-lvh { height: 100vh; }
  #shopify-section-{{ section.id }} .pointer-events-none { pointer-events: none; }
  #shopify-section-{{ section.id }} .z-0 { z-index: 0; }
  #shopify-section-{{ section.id }} .flex { display: flex; }
  #shopify-section-{{ section.id }} .justify-center { justify-content: center; }
  #shopify-section-{{ section.id }} .m-0 { margin: 0; }
  #shopify-section-{{ section.id }} .w-\[calc\(var\(--hero-ring-radius\)\*2\)\] { width: calc(var(--hero-ring-radius) * 2); }
  #shopify-section-{{ section.id }} .h-\[calc\(var\(--hero-ring-radius\)\*2\)\] { height: calc(var(--hero-ring-radius) * 2); }
  #shopify-section-{{ section.id }} .whitespace-pre { white-space: pre; }
  #shopify-section-{{ section.id }} .inline-block { display: inline-block; }
  
  #shopify-section-{{ section.id }} .hero-heading {
    color: var(--text-color);
    font-weight: 100;
  }
  
  #shopify-section-{{ section.id }} .hero-text-ring {
    --hero-ring-letter-size: calc(var(--hero-ring-radius) * 0.35);
    perspective: 5400px;
    
    top: 42.2vmin;
  }

  /* tall-phone */
  @media (min-width: 375px) and (max-width: 430px) {
    #shopify-section-{{ section.id }} .hero-text-ring { top: 54.5vmin; }
  }
  /* small-phone */
  @media (max-width: 374px) {
    #shopify-section-{{ section.id }} .hero-text-ring { top: 30.8vmin; }
  }
  /* mobile-landscape */
  @media (max-height: 500px) and (orientation: landscape) {
    #shopify-section-{{ section.id }} .hero-text-ring { top: 2.8vmin; }
  }
  /* sm */
  @media (min-width: 640px) {
    #shopify-section-{{ section.id }} .hero-text-ring { top: 16.6vmin; }
  }
  /* md */
  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .hero-text-ring { top: 12.6vmin; }
  }
  /* lg */
  @media (min-width: 1024px) {
    #shopify-section-{{ section.id }} .hero-text-ring { top: 9.2vmin; }
  }
  
  #shopify-section-{{ section.id }} .hero-ring {
    transform-style: preserve-3d;
    animation: hero-ring-spin {{ section.settings.spin_duration_s }}s linear infinite;
    animation-play-state: paused;
  }

  #shopify-section-{{ section.id }} .hero-ring[data-revealed="true"] {
    animation-play-state: running;
  }
  
  @keyframes hero-ring-spin {
    from { transform: rotateY(0deg); }
    to { transform: rotateY(360deg); }
  }

  #shopify-section-{{ section.id }} .hero-ring-letter {
    color: var(--text-color);
    font-size: var(--hero-ring-letter-size);
    font-weight: 100;
    letter-spacing: -0.08em;
    line-height: 1.5;
    padding: 0.2em 0.2em 0.4em 0.02em;
    opacity: 0;
  }

  #shopify-section-{{ section.id }} .hero-ring[data-revealed="true"] .hero-ring-letter {
    animation-name: hero-letter-reveal;
    animation-duration: 1200ms;
    animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
    animation-fill-mode: forwards;
    animation-delay: var(--reveal-delay, 0ms);
    transform: var(--letter-from);
  }

  @keyframes hero-letter-reveal {
    from {
      transform: var(--letter-from);
      opacity: 0;
    }
    to {
      transform: var(--letter-to);
      opacity: 1;
    }
  }
</style>

<div class="hero-wrapper">
  <div aria-hidden="true" class="absolute left-0 top-200 h-px w-px pointer-events-none"></div>
  <div aria-hidden="true" class="fixed inset-x-0 bottom-0 h-lvh pointer-events-none" style="opacity: 1; background-image: linear-gradient(to top, var(--gradient-color) 0%, transparent var(--gradient-height));"></div>
  {%- if heading_text != blank -%}
    <h1 aria-label="{{ heading_text | escape }}" class="hero-text-ring fixed inset-x-0 z-0 flex justify-center pointer-events-none m-0">
      <div class="w-[calc(var(--hero-ring-radius)*2)] h-[calc(var(--hero-ring-radius)*2)]">
        <div class="hero-ring relative w-[calc(var(--hero-ring-radius)*2)] h-[calc(var(--hero-ring-radius)*2)]">
          {%- for letter in letters -%}
            {%- assign current_angle = section.settings.start_angle | plus: forloop.index0 | times: angle_increment -%}
            {%- assign from_angle = current_angle | minus: section.settings.reveal_offset_angle -%}
            {%- assign reveal_delay = section.settings.reveal_delay_start_ms | plus: forloop.index0 | times: section.settings.reveal_delay_increment_ms -%}
            <span
              aria-hidden="true"
              class="hero-ring-letter absolute left-1/2 top-1/2 whitespace-pre inline-block"
              style="
                --reveal-delay: {{ reveal_delay }}ms;
                --letter-to: translate(-50%, -50%) rotateY({{ current_angle }}deg) translateZ(var(--hero-ring-radius));
                --letter-from: translate(-50%, -50%) rotateY({{ from_angle }}deg) translateZ(var(--hero-ring-radius));
              "
            >{{ letter }}</span>
          {%- endfor -%}
        </div>
      </div>
    </h1>
  {%- endif -%}
</div>

<script>
  (function() {
    const section = document.getElementById('shopify-section-{{ section.id }}');
    if (!section) return;

    const heroRing = section.querySelector('.hero-ring');
    if (!heroRing) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          heroRing.setAttribute('data-revealed', 'true');
        } else {
          // Optional: remove attribute to pause animation when out of view
          // heroRing.removeAttribute('data-revealed');
        }
      });
    }, {
      rootMargin: '0px',
      threshold: 0.1
    });

    observer.observe(section);
  })();
</script>

{% schema %}
{
  "name": "3D Hero Text",
  "tag": "section",
  "class": "shopify-section-hero-3d-text",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Everywhere"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Layout & Animation"
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Section scroll height",
      "min": 100,
      "max": 500,
      "step": 10,
      "unit": "vh",
      "default": 200
    },
    {
      "type": "range",
      "id": "ring_radius",
      "label": "Ring radius",
      "min": 20,
      "max": 60,
      "step": 1,
      "unit": "vm",
      "default": 37
    },
    {
      "type": "range",
      "id": "spread_angle",
      "label": "Text spread angle",
      "min": 45,
      "max": 360,
      "step": 5,
      "unit": "deg",
      "default": 90,
      "info": "The total angle the text will occupy in the ring."
    },
    {
      "type": "range",
      "id": "start_angle",
      "label": "Ring start rotation",
      "min": 0,
      "max": 360,
      "step": 5,
      "unit": "deg",
      "default": 0,
      "info": "The starting rotation of the text ring."
    },
    {
      "type": "range",
      "id": "spin_duration_s",
      "label": "Spin duration",
      "min": 10,
      "max": 120,
      "step": 5,
      "unit": "s",
      "default": 40
    },
    {
      "type": "range",
      "id": "reveal_offset_angle",
      "label": "Reveal animation angle",
      "min": 5,
      "max": 45,
      "step": 1,
      "unit": "deg",
      "default": 15
    },
    {
      "type": "range",
      "id": "reveal_delay_start_ms",
      "label": "Reveal animation delay",
      "min": 0,
      "max": 3000,
      "step": 100,
      "unit": "ms",
      "default": 500
    },
    {
      "type": "range",
      "id": "reveal_delay_increment_ms",
      "label": "Delay between letters",
      "min": 10,
      "max": 200,
      "step": 5,
      "unit": "ms",
      "default": 55
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background color",
      "default": "#090909"
    },
    {
      "type": "color",
      "id": "gradient_color",
      "label": "Bottom gradient color",
      "default": "#090909"
    },
    {
      "type": "range",
      "id": "gradient_height",
      "label": "Bottom gradient height",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "%",
      "default": 34
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "3D Hero Text"
    }
  ]
}
{% endschema %}