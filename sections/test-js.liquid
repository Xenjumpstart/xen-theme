      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "grid_item",
      "name": "Grid Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Item Heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Describe the item in a few words.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Online Features",
      "settings": {
        "featured_heading": "Your AI sales associate",
        "featured_text": "<p>Enter text here</p>",
        "featured_button_label": "Get Shopify Inbox",
        "featured_link_label": "Explore AI messaging apps"
      },
      "blocks": [
        {
          "type": "grid_item",
          "settings": {
            "heading": "Storefront search delivers more results",
            "text": "<p>Make it easier for customers to find what they're looking for. Search is now more forgiving of typos and returns more relevant results, including blog posts and pages.</p>"
          }
        },
        {
          "type": "grid_item",
          "settings": {
            "heading": "More relevant product recommendations",
            "text": "<p>The new Recommendations API uses a customer's real-time activities like adding to cart and searching to generate personalized suggestions on product pages.</p>"
          }
        },
        {
          "type": "grid_item",
          "settings": {
            "heading": "Semantic search",
            "text": "<p>Semantic search goes beyond keywords to better understand customer intent. Now customers can find products using conversational and descriptive terms.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}